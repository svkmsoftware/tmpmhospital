# ─────────────────────────────────────────────────────────────────────────────
# TMPM Hospital — Local Development Environment
# This file is gitignored. Never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Strapi CMS ────────────────────────────────────────────────────────────────
# The vendor's Strapi server (pre-filled for you)
STRAPI_API_URL=https://shirpurhospital.kwebmakerdigitalagency.com

# Ask the vendor for a Read-only API token:
# Strapi Admin → Settings → API Tokens → Create new token
# Type: Read-only, Duration: Unlimited
STRAPI_API_TOKEN=

# Set to "true" to fetch from Strapi, "false" to use local mock data only
USE_STRAPI=true

# ── Analytics (optional for local dev) ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── Webhook Security ──────────────────────────────────────────────────────────
# A random secret string — generate with: openssl rand -hex 32
# Used to verify that webhook calls come from Strapi, not someone else
REVALIDATE_SECRET=change_this_to_a_long_random_string
